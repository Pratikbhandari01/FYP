EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_USE_SSL=False
EMAIL_TIMEOUT=30

# Credentials
# Gmail: EMAIL_HOST_USER=yourgmail@gmail.com, EMAIL_HOST_PASSWORD=<gmail-app-password>
# SendGrid: EMAIL_HOST_USER=apikey, EMAIL_HOST_PASSWORD=<sendgrid-api-key>
# Brevo: EMAIL_HOST_USER=<brevo-smtp-login>, EMAIL_HOST_PASSWORD=<brevo-smtp-key>
EMAIL_HOST_USER=pratikbhandari992@gmail.com
EMAIL_HOST_PASSWORD=

# Fallback password key used by current project settings
# If EMAIL_HOST_PASSWORD is empty, SMTP_MAIL will be used.

